---
import '../styles/cefic-tokens.css';

interface Props {
  title: string;
  description?: string;
  variant?: 'landing' | 'dashboard' | 'page';
  heroOverlap?: boolean;
}

const {
  title,
  description = 'Monthly Chemical Trends — Cefic analysis based on Eurostat data',
  variant = 'page',
  heroOverlap = false,
} = Astro.props;

const bodyClass = variant === 'dashboard' ? 'ov-active' : '';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" />
  <title>{title}</title>
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('iris-theme');
      const theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    })();
  </script>
</head>
<body class={bodyClass}>
  <header class={`iris-header ${heroOverlap ? 'is-transparent' : ''}`} id="iris-header" data-overlap={heroOverlap}>
    {variant === 'dashboard' && (
      <button class="iris-burger" id="iris-burger" type="button" aria-label="Open navigation">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7"  x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    )}
    <a class="iris-brand" href="/">
      <img src="/cefic-logo.png" alt="Cefic" />
      <span class="iris-brand-stack">
        <span class="iris-brand-mark">Iris</span>
        <span class="iris-brand-by">by Cefic</span>
      </span>
    </a>
    <nav class="iris-nav">
      {variant === 'dashboard' ? (
        <a class="iris-back-link" href="/">All editions</a>
      ) : (
        <>
          <a href="/" data-desktop>Editions</a>
          <a href="https://cefic.org" target="_blank" rel="noopener" data-desktop>Cefic.org</a>
        </>
      )}
      <button class="iris-theme-toggle" id="iris-theme-toggle" type="button" aria-label="Toggle dark mode">
        <span id="iris-theme-label">Light</span>
      </button>
    </nav>
  </header>

  <slot />

  {variant !== 'dashboard' && (
    <footer class="iris-footer">
      <div class="iris-footer-inner">
        <div>
          <div class="iris-footer-brand">
            <img src="/cefic-logo.png" alt="Cefic" />
            <span class="iris-footer-brand-name">Iris</span>
          </div>
          <p>Monthly Chemical Trends — a Cefic publication monitoring the European chemical industry through Eurostat and Comext data.</p>
        </div>
        <div>
          <div class="iris-footer-col-title">Publication</div>
          <p><a href="/">All editions</a></p>
          <p><a href="/">Methodology</a></p>
          <p><a href="/">Data sources</a></p>
        </div>
        <div>
          <div class="iris-footer-col-title">Cefic</div>
          <p><a href="https://cefic.org" target="_blank" rel="noopener">cefic.org</a></p>
          <p><a href="https://cefic.org/our-industry/" target="_blank" rel="noopener">Our industry</a></p>
          <p><a href="https://cefic.org/media-corner/" target="_blank" rel="noopener">Media corner</a></p>
        </div>
      </div>
      <div class="iris-footer-bottom">
        <div>© {new Date().getFullYear()} Cefic — European Chemical Industry Council</div>
        <div>Data: Eurostat · Comext</div>
      </div>
    </footer>
  )}

  <script is:inline>
    (function () {
      const root  = document.documentElement;
      const btn   = document.getElementById('iris-theme-toggle');
      const label = document.getElementById('iris-theme-label');
      if (!btn || !label) return;
      const sync = () => { label.textContent = root.dataset.theme === 'dark' ? 'Dark' : 'Light'; };
      sync();
      btn.addEventListener('click', () => {
        root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('iris-theme', root.dataset.theme);
        sync();
      });
    })();

    // Transparent header scroll behaviour (landing only)
    (function () {
      const header = document.getElementById('iris-header');
      if (!header || header.dataset.overlap !== 'true') return;
      const onScroll = () => {
        if (window.scrollY > 120) header.classList.remove('is-transparent');
        else                      header.classList.add('is-transparent');
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
</body>
</html>
