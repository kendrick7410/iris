---
import '../styles/cefic-tokens.css';

interface Props {
  title: string;
  description?: string;
  variant?: 'landing' | 'dashboard' | 'page';
  heroOverlap?: boolean;
}

const {
  title,
  description = 'Monthly Chemical Trends. Cefic analysis based on Eurostat data.',
  variant = 'page',
  heroOverlap = false,
} = Astro.props;

const bodyClass = variant === 'dashboard' ? 'ov-active' : '';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" />
  <title>{title}</title>
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('iris-theme');
      const theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    })();
  </script>
</head>
<body class={bodyClass}>
  <header class={`iris-header ${heroOverlap ? 'is-transparent' : ''}`} id="iris-header" data-overlap={heroOverlap}>
    {variant === 'dashboard' && (
      <button class="iris-burger" id="iris-burger" type="button" aria-label="Open navigation">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7"  x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    )}
    <a class="iris-brand" href="/">
      <img src="/cefic-logo.png" alt="Cefic" />
      <span class="iris-brand-stack">
        <span class="iris-brand-mark">Iris</span>
        <span class="iris-brand-by">by Cefic</span>
      </span>
    </a>
    <nav class="iris-nav">
      {variant === 'dashboard' ? (
        <a class="iris-back-link" href="/"><span>All editions</span></a>
      ) : (
        <>
          <a href="/" data-desktop>Editions</a>
          <a href="https://cefic.org" target="_blank" rel="noopener" data-desktop>Cefic.org</a>
        </>
      )}
      <button class="iris-theme-toggle" id="iris-theme-toggle" type="button" aria-label="Toggle dark mode">
        <span id="iris-theme-label">Light</span>
      </button>
    </nav>
  </header>

  <slot />

  <!-- Chart lightbox (global: available on every page) -->
  <dialog class="iris-lightbox" id="iris-lightbox" aria-label="Chart zoom">
    <button class="iris-lightbox-close" id="iris-lightbox-close" type="button" aria-label="Close">×</button>
    <div class="iris-lightbox-caption" id="iris-lightbox-caption"></div>
    <img class="iris-lightbox-img" id="iris-lightbox-img" alt="" />
    <div class="iris-lightbox-inline" id="iris-lightbox-inline"></div>
  </dialog>

  {variant !== 'dashboard' && (
    <footer class="iris-footer">
      <div class="iris-footer-inner">
        <div>
          <div class="iris-footer-brand">
            <img src="/cefic-logo.png" alt="Cefic" />
            <span class="iris-footer-brand-name">Iris</span>
          </div>
          <p>Monthly Chemical Trends. A Cefic publication monitoring the European chemical industry through Eurostat and Comext data.</p>
        </div>
        <div>
          <div class="iris-footer-col-title">Publication</div>
          <p><a href="/">All editions</a></p>
          <p><a href="/">Methodology</a></p>
          <p><a href="/">Data sources</a></p>
        </div>
        <div>
          <div class="iris-footer-col-title">Cefic</div>
          <p><a href="https://cefic.org" target="_blank" rel="noopener">cefic.org</a></p>
          <p><a href="https://cefic.org/our-industry/" target="_blank" rel="noopener">Our industry</a></p>
          <p><a href="https://cefic.org/media-corner/" target="_blank" rel="noopener">Media corner</a></p>
        </div>
      </div>
      <div class="iris-footer-bottom">
        <div>© {new Date().getFullYear()} Cefic. European Chemical Industry Council.</div>
        <div>Data: Eurostat · Comext</div>
      </div>
    </footer>
  )}

  <script is:inline>
    (function () {
      const root  = document.documentElement;
      const btn   = document.getElementById('iris-theme-toggle');
      const label = document.getElementById('iris-theme-label');
      if (!btn || !label) return;
      const sync = () => { label.textContent = root.dataset.theme === 'dark' ? 'Dark' : 'Light'; };
      sync();
      btn.addEventListener('click', () => {
        root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('iris-theme', root.dataset.theme);
        sync();
      });
    })();

    // Transparent header scroll behaviour (landing only)
    (function () {
      const header = document.getElementById('iris-header');
      if (!header || header.dataset.overlap !== 'true') return;
      const onScroll = () => {
        if (window.scrollY > 120) header.classList.remove('is-transparent');
        else                      header.classList.add('is-transparent');
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();

    // Chart lightbox (any figure with .iris-chart-zoom button)
    (function () {
      const dlg    = document.getElementById('iris-lightbox');
      const img    = document.getElementById('iris-lightbox-img');
      const cap    = document.getElementById('iris-lightbox-caption');
      const inline = document.getElementById('iris-lightbox-inline');
      const close  = document.getElementById('iris-lightbox-close');
      if (!dlg || !img || !inline) return;

      const showImg = (src, title) => {
        img.src = src;
        img.alt = title || '';
        img.style.display = 'block';
        inline.innerHTML = '';
      };
      const showInline = (targetSel, title) => {
        const src = document.querySelector(targetSel);
        if (!src) return;
        img.style.display = 'none';
        img.src = '';
        // Clone the SVG so IDs don't collide; strip the zoom button copy
        const clone = src.cloneNode(true);
        clone.querySelectorAll('.iris-chart-zoom').forEach(el => el.remove());
        inline.innerHTML = '';
        inline.appendChild(clone);
      };

      const open = (btn) => {
        const title = btn.dataset.chartTitle || '';
        cap.textContent = title;
        if (btn.dataset.chartTarget) showInline(btn.dataset.chartTarget, title);
        else if (btn.dataset.chartSrc) showImg(btn.dataset.chartSrc, title);
        if (typeof dlg.showModal === 'function') dlg.showModal();
        else dlg.setAttribute('open', '');
      };
      const closeLightbox = () => {
        if (typeof dlg.close === 'function') dlg.close();
        else dlg.removeAttribute('open');
        img.src = '';
        inline.innerHTML = '';
      };

      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.iris-chart-zoom');
        if (btn) {
          e.preventDefault();
          open(btn);
          return;
        }
        if (e.target === dlg) closeLightbox();
      });
      close?.addEventListener('click', closeLightbox);
      dlg.addEventListener('cancel', (e) => { e.preventDefault(); closeLightbox(); });
    })();
  </script>
</body>
</html>
