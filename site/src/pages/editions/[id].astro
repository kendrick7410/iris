---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const editions = await getCollection('editions');
  return editions.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const monthName = (id: string) => {
  const [y, m] = id.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
};

// Resolve project root (Astro cwd = site/ during dev and build)
const PROJECT_ROOT = path.resolve('..');

// Load fiches at build time (graceful: some may be absent for older editions)
const fichesDir = path.join(PROJECT_ROOT, 'data', 'processed', entry.id, 'fiches');
const loadFiche = (name: string): any | null => {
  try {
    return JSON.parse(fs.readFileSync(path.join(fichesDir, `${name}.json`), 'utf8'));
  } catch {
    return null;
  }
};

const tradeExports = loadFiche('trade_exports');
const tradeImports = loadFiche('trade_imports');
const macroFiche   = loadFiche('macro_brief');
const outputFiche  = loadFiche('output');
const pricesFiche  = loadFiche('prices');
const salesFiche   = loadFiche('sales');

// ---------- Smooth inline SVG line chart helper ----------
type SeriesPoint = { period: string; value: number };
type SparkSpec = {
  id: string;
  points: SeriesPoint[];
  stroke: string;
  unit: string;
  // yoy is computed inside buildSpark to render a small delta badge
};

const buildSpark = (series: SeriesPoint[] | null | undefined, stroke: string, unit: string) => {
  if (!series || series.length < 2) return null;
  const W = 600, H = 240;
  const padL = 48, padR = 24, padT = 20, padB = 36;
  const w = W - padL - padR;
  const h = H - padT - padB;

  const values = series.map(s => s.value);
  const vmin = Math.min(...values);
  const vmax = Math.max(...values);
  const vpad = (vmax - vmin) * 0.12 || 1;
  const ymin = vmin - vpad;
  const ymax = vmax + vpad;

  const pts = series.map((s, i) => {
    const x = padL + (i / (series.length - 1)) * w;
    const y = padT + (1 - (s.value - ymin) / (ymax - ymin)) * h;
    return { x, y, period: s.period, value: s.value };
  });

  // Catmull-Rom -> cubic Bezier
  const P = pts;
  let d = `M ${P[0].x.toFixed(2)} ${P[0].y.toFixed(2)}`;
  for (let i = 1; i < P.length; i++) {
    const p0 = P[i-2] || P[i-1];
    const p1 = P[i-1];
    const p2 = P[i];
    const p3 = P[i+1] || P[i];
    const cp1x = p1.x + (p2.x - p0.x) / 6;
    const cp1y = p1.y + (p2.y - p0.y) / 6;
    const cp2x = p2.x - (p3.x - p1.x) / 6;
    const cp2y = p2.y - (p3.y - p1.y) / 6;
    d += ` C ${cp1x.toFixed(2)} ${cp1y.toFixed(2)}, ${cp2x.toFixed(2)} ${cp2y.toFixed(2)}, ${p2.x.toFixed(2)} ${p2.y.toFixed(2)}`;
  }

  // Area fill path (line + down + left + up)
  const areaD = d
    + ` L ${P[P.length-1].x.toFixed(2)} ${(padT + h).toFixed(2)}`
    + ` L ${P[0].x.toFixed(2)} ${(padT + h).toFixed(2)} Z`;

  // Axis ticks: X = every 2 months, Y = 3 gridlines
  const xTicks = series.map((s, i) => ({ i, period: s.period }))
    .filter((_, i) => i % Math.max(1, Math.floor(series.length / 6)) === 0 || i === series.length - 1);
  const yTicks = [0, 0.5, 1].map(f => {
    const v = ymin + (ymax - ymin) * (1 - f);
    const y = padT + f * h;
    return { y, v };
  });

  // YoY delta: first vs last
  const first = series[0].value;
  const last  = series[series.length - 1].value;
  const deltaPct = ((last - first) / first) * 100;

  return {
    W, H, padL, padR, padT, padB, w, h,
    pts, d, areaD, xTicks, yTicks,
    stroke, unit,
    current: last,
    deltaPct,
    first, last,
    periodStart: series[0].period,
    periodEnd: series[series.length - 1].period,
  };
};

const fmtMonth = (ym: string) => {
  const [y, m] = ym.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'short', year: '2-digit' });
};

const outputSpark = buildSpark(outputFiche?.data?.monthly_series, 'var(--cefic-orange)', 'Index (2021=100)');
const pricesSpark = buildSpark(pricesFiche?.data?.monthly_series, 'var(--cefic-blue-1)',  'Index (2021=100)');
const salesSpark  = buildSpark(salesFiche?.data?.monthly_series,  'var(--cefic-green-1)', 'Index (2021=100)');

// ---------- Long-arc balance chart (60 months) ----------
type BalancePoint = { period: string; value_eur_bn: number };
const buildBalanceChart = (series: BalancePoint[] | null | undefined) => {
  if (!series || series.length < 2) return null;
  const W = 960, H = 340;
  const padL = 56, padR = 24, padT = 28, padB = 40;
  const w = W - padL - padR;
  const h = H - padT - padB;

  const values = series.map(s => s.value_eur_bn);
  const vmin = Math.min(...values, 0);
  const vmax = Math.max(...values, 0);
  const vpad = (vmax - vmin) * 0.10 || 1;
  const ymin = vmin - vpad;
  const ymax = vmax + vpad;

  const yScale = (v: number) => padT + (1 - (v - ymin) / (ymax - ymin)) * h;
  const xScale = (i: number) => padL + (i / (series.length - 1)) * w;
  const zeroY = yScale(0);

  const pts = series.map((s, i) => ({
    x: xScale(i), y: yScale(s.value_eur_bn),
    period: s.period, value: s.value_eur_bn,
  }));

  let d = `M ${pts[0].x.toFixed(2)} ${pts[0].y.toFixed(2)}`;
  for (let i = 1; i < pts.length; i++) {
    const p0 = pts[i-2] || pts[i-1];
    const p1 = pts[i-1], p2 = pts[i], p3 = pts[i+1] || pts[i];
    const cp1x = p1.x + (p2.x - p0.x) / 6;
    const cp1y = p1.y + (p2.y - p0.y) / 6;
    const cp2x = p2.x - (p3.x - p1.x) / 6;
    const cp2y = p2.y - (p3.y - p1.y) / 6;
    d += ` C ${cp1x.toFixed(2)} ${cp1y.toFixed(2)}, ${cp2x.toFixed(2)} ${cp2y.toFixed(2)}, ${p2.x.toFixed(2)} ${p2.y.toFixed(2)}`;
  }

  // X ticks at every 12 months
  const xTicks = series.map((s, i) => ({ i, period: s.period }))
    .filter((_, i) => i === 0 || i === series.length - 1 || i % 12 === 0);
  const yTicksVals = [ymin, (ymin + ymax) / 2, 0, ymax].filter(v => v >= ymin && v <= ymax);
  const yTicks = Array.from(new Set(yTicksVals.map(v => Math.round(v * 10) / 10)))
    .sort((a, b) => a - b)
    .map(v => ({ v, y: yScale(v) }));

  return { W, H, padL, padR, padT, padB, w, h, pts, d, zeroY, xTicks, yTicks, yScale, xScale };
};

const balance60m = buildBalanceChart(tradeExports?.data?.historical_series?.trade_balance_monthly);

// ---------- Long-arc partners chart (60 months) ----------
type PartnerSeries = Record<string, BalancePoint[]>;
const buildPartnersChart = (series_by: PartnerSeries | null | undefined, currentMonth: string) => {
  if (!series_by || !series_by.US) return null;
  const partners = [
    { code: 'US',    label: 'United States', color: '#F47B20', weight: 2.2 },
    { code: 'GB',    label: 'United Kingdom', color: '#005CAB', weight: 1.3 },
    { code: 'CN',    label: 'China',         color: '#00A99E', weight: 1.3 },
    { code: 'CH',    label: 'Switzerland',   color: '#79B777', weight: 1.1 },
    { code: 'OTHER', label: 'Other',         color: '#aaaaaa', weight: 1.0 },
  ];
  const first = series_by.US;
  if (!first || first.length < 2) return null;

  const W = 960, H = 380;
  const padL = 56, padR = 24, padT = 40, padB = 44;
  const w = W - padL - padR;
  const h = H - padT - padB;

  // Y domain from max across all partners
  const allValues = partners.flatMap(p => (series_by[p.code] || []).map(s => s.value_eur_bn));
  const vmin = 0;
  const vmax = Math.max(...allValues);
  const vpad = vmax * 0.08 || 1;
  const ymax = vmax + vpad;

  const yScale = (v: number) => padT + (1 - (v - vmin) / (ymax - vmin)) * h;
  const xScale = (i: number) => padL + (i / (first.length - 1)) * w;

  const seriesData = partners.map(p => {
    const data = series_by[p.code] || [];
    if (data.length < 2) return { ...p, pts: [], d: '' };
    const pts = data.map((s, i) => ({
      x: xScale(i), y: yScale(s.value_eur_bn),
      period: s.period, value: s.value_eur_bn,
    }));
    let d = `M ${pts[0].x.toFixed(2)} ${pts[0].y.toFixed(2)}`;
    for (let i = 1; i < pts.length; i++) {
      const p0 = pts[i-2] || pts[i-1];
      const p1 = pts[i-1], p2 = pts[i], p3 = pts[i+1] || pts[i];
      const cp1x = p1.x + (p2.x - p0.x) / 6;
      const cp1y = p1.y + (p2.y - p0.y) / 6;
      const cp2x = p2.x - (p3.x - p1.x) / 6;
      const cp2y = p2.y - (p3.y - p1.y) / 6;
      d += ` C ${cp1x.toFixed(2)} ${cp1y.toFixed(2)}, ${cp2x.toFixed(2)} ${cp2y.toFixed(2)}, ${p2.x.toFixed(2)} ${p2.y.toFixed(2)}`;
    }
    const current = pts.find(pt => pt.period === currentMonth);
    return { ...p, pts, d, current };
  });

  const xTicks = first.map((s, i) => ({ i, period: s.period }))
    .filter((_, i) => i === 0 || i === first.length - 1 || i % 12 === 0);
  const yTicks = [0, ymax * 0.25, ymax * 0.5, ymax * 0.75, ymax]
    .map(v => ({ v, y: yScale(v) }));

  return {
    W, H, padL, padR, padT, padB, w, h,
    partners: seriesData,
    xTicks, yTicks,
    periods: first.length,
  };
};

const partners60m = buildPartnersChart(tradeExports?.data?.historical_series?.exports_by_partner_monthly, entry.id);

// Chart helpers: confirm presence before referencing
const chartsDir = path.resolve(`public/charts/${entry.id}`);
const chartExists = (id: string): boolean => {
  try { return fs.statSync(path.join(chartsDir, `${id}.svg`)).isFile(); }
  catch { return false; }
};
const chartUrl = (id: string) => `/charts/${entry.id}/${id}.svg`;

// Build KPI cards from the macro fiche when available, else fall back to hardcoded
const kpis = (() => {
  if (macroFiche && macroFiche.kpi_cards) {
    return macroFiche.kpi_cards.map((k: any) => ({
      label: k.label,
      value: k.value_formatted || k.value,
      delta: k.yoy_formatted || k.yoy || '',
      dir:   (k.yoy && Number(k.yoy) > 0) ? 'pos' : 'neg',
      foot:  k.footnote || k.period || '',
    }));
  }
  return [
    { label: 'EU27 chemical exports', value: '€34.5 bn', delta: '-42.1%', dir: 'neg', foot: 'Jan-Feb 2026, YoY' },
    { label: 'Production index',      value: '79.3',     delta: '-3.9%',  dir: 'neg', foot: 'Feb 2026, 2021=100' },
    { label: 'Producer prices',       value: '117.2',    delta: '-2.8%',  dir: 'neg', foot: 'Feb 2026, YoY' },
    { label: 'Chemical sales',        value: '90.8',     delta: '-7.5%',  dir: 'neg', foot: 'Jan 2026, YoY' },
  ];
})();

// Partner drill-down data (US / CN / GB) from the trade_exports fiche when available
type PartnerCard = {
  code: string;
  label: string;
  value_now: string;
  delta_value: string;
  yoy_pct: string;
  dir: 'pos' | 'neg';
  share_pct: string;
  top_chapters: Array<{ label: string; yoy_pct: string; value_now: string }>;
};

const STRUCTURAL_PARTNERS: Array<{ code: string; label: string }> = [
  { code: 'US', label: 'United States' },
  { code: 'CN', label: 'China' },
  { code: 'GB', label: 'United Kingdom' },
];

const partnerCards: PartnerCard[] = (() => {
  if (!tradeExports?.data?.by_partner) return [];
  const byCode: Record<string, any> = {};
  for (const p of tradeExports.data.by_partner) {
    if (p.partner) byCode[p.partner] = p;
  }
  const cards: PartnerCard[] = [];
  for (const sp of STRUCTURAL_PARTNERS) {
    const p = byCode[sp.code];
    if (!p) continue;
    const delta = Number((p.value_eur_bn - p.previous_year_value_eur_bn).toFixed(2));
    cards.push({
      code: sp.code,
      label: sp.label,
      value_now: `€${p.value_eur_bn.toFixed(2)} bn`,
      delta_value: `${delta >= 0 ? '+' : ''}${delta.toFixed(2)} bn`,
      yoy_pct: `${p.yoy_pct >= 0 ? '+' : ''}${p.yoy_pct.toFixed(1)}%`,
      dir: p.yoy_pct >= 0 ? 'pos' : 'neg',
      share_pct: `${p.share_pct.toFixed(1)}%`,
      top_chapters: (p.top_nace || []).slice(0, 3).map((c: any) => {
        const hasYoy = c.yoy_pct !== undefined && c.yoy_pct !== null && c.yoy_pct !== 0;
        return {
          label: (c.label || '').split(',')[0].slice(0, 40),
          yoy_pct: hasYoy ? `${c.yoy_pct >= 0 ? '+' : ''}${c.yoy_pct.toFixed(1)}%` : '',
          value_now: `€${(c.value_eur_bn ?? 0).toFixed(2)} bn`,
        };
      }),
    });
  }
  return cards;
})();

// Country YoY for macro brief view (from output fiche eventually — hardcoded fallback)
const countryPerf = [
  { label: 'Netherlands', value: -9.6 },
  { label: 'Italy',       value: -6.9 },
  { label: 'Germany',     value: -3.5 },
  { label: 'Spain',       value: -3.3 },
  { label: 'Poland',      value: -2.1 },
  { label: 'Belgium',     value: -1.2 },
  { label: 'France',      value:  1.1 },
];
const maxMag = Math.max(...countryPerf.map(c => Math.abs(c.value)));

const has60mBalance  = chartExists('trade_balance_monthly_60m');
const has60mPartner  = chartExists('exports_by_partner_60m');
const hasOutputIdx   = chartExists('output_index');
const hasPricesIdx   = chartExists('prices_index');
const hasTurnoverIdx = chartExists('turnover_index');
const hasOutputYoY   = chartExists('output_yoy_country');
const hasImpWaterfall = chartExists('trade_imports_waterfall_cn8');

// Download PDF (present only if generated)
const pdfRelPath = `public/downloads/${entry.id}.pdf`;
const pdfExists  = (() => {
  try { return fs.statSync(pdfRelPath).isFile(); }
  catch { return false; }
})();
const pdfUrl     = `/downloads/${entry.id}.pdf`;
const pdfName    = `Iris-${monthName(entry.id).replace(' ', '-')}.pdf`;
---
<Layout
  title={`Iris: ${monthName(entry.id)} edition`}
  variant="dashboard"
>
  <div class="iris-drawer-scrim" id="iris-drawer-scrim"></div>

  <aside class="iris-drawer" id="iris-drawer" data-open="false" aria-hidden="true">
    <div class="iris-drawer-header">
      <h2 class="iris-drawer-title">{monthName(entry.id)}</h2>
      <button class="iris-drawer-close" id="iris-drawer-close" type="button" aria-label="Close">×</button>
    </div>
    <div class="iris-drawer-section">
      <div class="iris-drawer-section-title">Start</div>
      <button class="iris-drawer-item" data-view="overview" data-active="true">Overview</button>
    </div>
    <div class="iris-drawer-section">
      <div class="iris-drawer-section-title">Main</div>
      <button class="iris-drawer-item" data-view="macro">Macro brief</button>
      <button class="iris-drawer-item" data-view="drilldown">Drill-down</button>
    </div>
    <div class="iris-drawer-section">
      <div class="iris-drawer-section-title">Archive</div>
      <a class="iris-drawer-item" href="/">Back to all editions</a>
    </div>
  </aside>

  <main class="iris-dashboard">
    <div class="iris-view-controls">
      <div class="iris-view-tabs" role="tablist">
        <button class="iris-view-tab" data-view="overview"  data-active="true" role="tab">Overview</button>
        <button class="iris-view-tab" data-view="macro"     role="tab">Macro brief</button>
        <button class="iris-view-tab" data-view="drilldown" role="tab">Drill-down</button>
      </div>
      {pdfExists && (
        <a class="iris-download-btn" href={pdfUrl} download={pdfName}
           aria-label={`Download ${monthName(entry.id)} edition as PDF`}>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 2v9M4 7l4 4 4-4M2 14h12" />
          </svg>
          <span>Download the report</span>
        </a>
      )}
    </div>

    <!-- ===== OVERVIEW ===== -->
    <section class="iris-view" data-view="overview" data-active="true">
      <header class="iris-view-header">
        <div>
          <div class="iris-view-eyebrow">Overview, {monthName(entry.id)}</div>
          <h1 class="iris-view-title">EU27 chemical exports fall 42% amid anomalous base effects</h1>
        </div>
        <div class="iris-view-subtitle">Published {entry.data.publication_date}</div>
      </header>

      <div class="iris-kpi-grid">
        {kpis.map((k: any) => (
          <div class="iris-kpi-card">
            <div class="iris-kpi-label">{k.label}</div>
            <div class="iris-kpi-value">{k.value}</div>
            <div class={`iris-kpi-delta is-${k.dir}`}>{k.delta}</div>
            <div class="iris-kpi-foot">{k.foot}</div>
          </div>
        ))}
      </div>

      <div class="iris-cols iris-view-body">
        {balance60m && (
          <figure class="iris-chart" id="chart-balance-60m">
            <figcaption class="iris-chart-caption">
              EU27 chemical trade balance, 60-month context. The Q1 2025 spike reflects
              pre-tariff front-loading ahead of US trade measures; the February 2026
              reading sits at €0.21 bn, down €12.21 bn from 2025.
            </figcaption>
            <button class="iris-chart-zoom" type="button" aria-label="Zoom"
                    data-chart-target="#chart-balance-60m"
                    data-chart-title="EU27 chemical trade balance, 60 months (Mar 2021 to Feb 2026)">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4"/></svg>
            </button>
            <svg class="iris-sparkchart iris-chart-hover"
                 viewBox={`0 0 ${balance60m.W} ${balance60m.H}`}
                 xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
              {balance60m.yTicks.map((t: any) => (
                <>
                  <line class="gridline" x1={balance60m.padL} x2={balance60m.W - balance60m.padR} y1={t.y} y2={t.y} />
                  <text class="axis-text" x={balance60m.padL - 6} y={t.y + 3} text-anchor="end">{t.v.toFixed(1)}</text>
                </>
              ))}
              <line x1={balance60m.padL} x2={balance60m.W - balance60m.padR} y1={balance60m.zeroY} y2={balance60m.zeroY}
                    stroke="var(--ink)" stroke-width="1.2" />
              <path d={`${balance60m.d} L ${balance60m.pts[balance60m.pts.length-1].x} ${balance60m.zeroY} L ${balance60m.pts[0].x} ${balance60m.zeroY} Z`}
                    fill="var(--cefic-green-1)" opacity="0.15" />
              <path d={balance60m.d} fill="none" stroke="var(--cefic-orange)" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round" />
              {balance60m.pts.map((p: any, i: number) => (
                <rect class="spark-hover-rect" x={p.x - 5} y={balance60m.padT} width={10} height={balance60m.h}
                      fill="transparent"
                      data-period={p.period} data-value={p.value.toFixed(2)} data-unit="€ bn"
                      data-label="EU27 trade balance" />
              ))}
              {balance60m.xTicks.map((t: any) => (
                <text class="axis-text" x={balance60m.padL + (t.i / (balance60m.pts.length - 1)) * balance60m.w}
                      y={balance60m.H - 14} text-anchor="middle">{fmtMonth(t.period)}</text>
              ))}
              <circle cx={balance60m.pts[balance60m.pts.length - 1].x} cy={balance60m.pts[balance60m.pts.length - 1].y} r="4.5"
                      fill="var(--cefic-orange)" stroke="var(--surface)" stroke-width="1.5" />
            </svg>
            <div class="iris-chart-tooltip" aria-hidden="true"></div>
          </figure>
        )}

        <div class="iris-panel">
          <h3 class="iris-panel-title">Key takeaway</h3>
          <p>
            Exports fell <strong>42.1%</strong> in value to €34.5 bn, amid an anomalous February 2025
            base driven by pre-tariff front-loading.
          </p>
          <p>
            Chemical output declined <strong>3.9% YoY</strong> in February, at 79.3 (2021 index),
            sitting <strong>18% below pre-crisis levels</strong> (2014-2019 average).
          </p>
          <p>
            Against a normalised 2024 base, exports declined by approximately 10%, a more
            representative indication of underlying weakness.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== MACRO BRIEF ===== -->
    <section class="iris-view" data-view="macro">
      <header class="iris-view-header">
        <div>
          <div class="iris-view-eyebrow">Macro brief, {monthName(entry.id)}</div>
          <h1 class="iris-view-title">Output down 3.9%, 18% below pre-crisis levels</h1>
        </div>
        <div class="iris-view-subtitle">Production, prices, sales</div>
      </header>

      <div class="iris-chart-row">
        {[
          { spark: outputSpark, id: 'chart-output-spark',  label: 'Output index',     title: 'EU27 chemical output, index (2021=100), monthly' },
          { spark: pricesSpark, id: 'chart-prices-spark',  label: 'Producer prices',  title: 'EU27 chemical producer prices, index (2021=100), monthly' },
          { spark: salesSpark,  id: 'chart-sales-spark',   label: 'Chemical sales',   title: 'EU27 chemical sales, index (2021=100), monthly' },
        ].map(({ spark, id, label, title }) => spark && (
          <figure class="iris-chart iris-chart--third" id={id}>
            <figcaption class="iris-chart-caption">{label} (2021=100)</figcaption>
            <button class="iris-chart-zoom" type="button" aria-label="Zoom"
                    data-chart-target={`#${id}`} data-chart-title={title}>
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4"/></svg>
            </button>
            <div class="iris-sparkheader">
              <span class="iris-sparkheader-value">{spark.current.toFixed(1)}</span>
              <span class={`iris-sparkheader-delta is-${spark.deltaPct >= 0 ? 'pos' : 'neg'}`}>
                {spark.deltaPct >= 0 ? '+' : ''}{spark.deltaPct.toFixed(1)}% since {fmtMonth(spark.periodStart)}
              </span>
            </div>
            <svg class="iris-sparkchart iris-chart-hover" viewBox={`0 0 ${spark.W} ${spark.H}`} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
              {spark.yTicks.map((t: any) => (
                <>
                  <line class="gridline" x1={spark.padL} x2={spark.W - spark.padR} y1={t.y} y2={t.y} />
                  <text class="axis-text" x={spark.padL - 6} y={t.y + 3} text-anchor="end">{t.v.toFixed(0)}</text>
                </>
              ))}
              <path class="spark-area" d={spark.areaD} fill={spark.stroke} />
              <path class="spark-line" d={spark.d} stroke={spark.stroke} />
              {spark.pts.map((p: any, i: number) => (
                <circle class="spark-point" cx={p.x} cy={p.y} r={i === spark.pts.length - 1 ? 4.5 : 2.5}
                        fill={spark.stroke} />
              ))}
              {spark.pts.map((p: any) => (
                <rect class="spark-hover-rect" x={p.x - 10} y={spark.padT} width={20} height={spark.h}
                      fill="transparent"
                      data-period={p.period} data-value={p.value.toFixed(1)} data-unit=""
                      data-label={label} data-color={spark.stroke} />
              ))}
              {spark.xTicks.map((t: any) => (
                <text class="axis-text" x={spark.padL + (t.i / (spark.pts.length - 1)) * spark.w}
                      y={spark.H - 14} text-anchor="middle">{fmtMonth(t.period)}</text>
              ))}
              <text class="spark-value"
                    x={spark.pts[spark.pts.length - 1].x - 4}
                    y={spark.pts[spark.pts.length - 1].y - 10}
                    text-anchor="end" fill={spark.stroke}>
                {spark.last.toFixed(1)}
              </text>
            </svg>
            <div class="iris-chart-tooltip" aria-hidden="true"></div>
          </figure>
        ))}
      </div>

      <div class="iris-cols iris-view-body">
        <div class="iris-panel">
          <h3 class="iris-panel-title">Sector context</h3>
          <p>
            Chemical production underperformed total manufacturing (,0.4% in February).
            Pharmaceuticals fell more sharply at 8.6%, basic metals dropped 0.7%, motor
            vehicles gained 2.0%.
          </p>
          <p>
            EU27 chemical output averaged <strong>79.1</strong> in the first two months of 2026,
            down 1.7% versus the same period in 2025. The sector remains structurally 18 points
            below its 2014-2019 baseline, a gap that has not closed since the 2022 energy shock.
          </p>
        </div>

        <div class="iris-panel">
          <h3 class="iris-panel-title">Country output, YoY</h3>
          <ul class="iris-bar-list">
            {countryPerf.map(c => {
              const pct = (Math.abs(c.value) / maxMag) * 100;
              const neg = c.value < 0;
              return (
                <li>
                  <span class="iris-bar-label">{c.label}</span>
                  <span class="iris-bar-track">
                    <span class={`iris-bar-fill ${neg ? 'is-neg' : ''}`} style={`width:${pct}%`}></span>
                  </span>
                  <span class="iris-bar-value">{c.value > 0 ? '+' : ''}{c.value.toFixed(1)}%</span>
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== DRILL-DOWN ===== -->
    <section class="iris-view" data-view="drilldown">
      <header class="iris-view-header">
        <div>
          <div class="iris-view-eyebrow">Drill-down, {monthName(entry.id)}</div>
          <h1 class="iris-view-title">Export contraction concentrated on the three structural partners</h1>
        </div>
        <div class="iris-view-subtitle">US, China, United Kingdom</div>
      </header>

      {partners60m && (
        <figure class="iris-chart iris-chart--wide iris-chart--tall" id="chart-partners-60m">
          <figcaption class="iris-chart-caption">
            EU27 chemical exports by partner, 60-month context. The United States (orange) pulled
            away from the cluster through 2022-2024, peaked in February 2025 (pre-tariff
            front-loading), and retraced toward the China/UK band in early 2026.
          </figcaption>
          <button class="iris-chart-zoom" type="button" aria-label="Zoom"
                  data-chart-target="#chart-partners-60m"
                  data-chart-title="EU27 chemical exports by partner (US, GB, CN, CH, Other), 60 months">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4"/></svg>
          </button>
          <svg class="iris-sparkchart iris-chart-hover"
               viewBox={`0 0 ${partners60m.W} ${partners60m.H}`}
               xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            {partners60m.yTicks.map((t: any) => (
              <>
                <line class="gridline" x1={partners60m.padL} x2={partners60m.W - partners60m.padR} y1={t.y} y2={t.y} />
                <text class="axis-text" x={partners60m.padL - 6} y={t.y + 3} text-anchor="end">{t.v.toFixed(1)}</text>
              </>
            ))}
            <g class="partner-legend">
              {partners60m.partners.map((p: any, i: number) => (
                <>
                  <line x1={partners60m.padL + i * 140} x2={partners60m.padL + i * 140 + 16}
                        y1={18} y2={18} stroke={p.color} stroke-width="2.5" />
                  <text class="axis-text" x={partners60m.padL + i * 140 + 22} y={22} fill="var(--ink)">{p.label}</text>
                </>
              ))}
            </g>
            {partners60m.partners.map((p: any) => (
              <path d={p.d} fill="none" stroke={p.color} stroke-width={p.weight}
                    stroke-linecap="round" stroke-linejoin="round" />
            ))}
            {partners60m.partners.map((p: any) =>
              p.current && (
                <circle cx={p.current.x} cy={p.current.y} r="5" fill={p.color}
                        stroke="var(--surface)" stroke-width="1.5" />
              )
            )}
            {partners60m.partners.map((partner: any) =>
              partner.pts.map((pt: any) => (
                <rect class="spark-hover-rect"
                      x={pt.x - 5} y={pt.y - 8} width={10} height={16}
                      fill="transparent"
                      data-period={pt.period}
                      data-value={pt.value.toFixed(2)}
                      data-unit="€ bn"
                      data-label={partner.label}
                      data-color={partner.color} />
              ))
            )}
            {partners60m.xTicks.map((t: any) => (
              <text class="axis-text"
                    x={partners60m.padL + (t.i / (partners60m.periods - 1)) * partners60m.w}
                    y={partners60m.H - 14} text-anchor="middle">{fmtMonth(t.period)}</text>
            ))}
          </svg>
          <div class="iris-chart-tooltip" aria-hidden="true"></div>
        </figure>
      )}

      {partnerCards.length > 0 ? (
        <div class="iris-partner-grid">
          {partnerCards.map((p: PartnerCard) => (
            <div class="iris-partner-card">
              <div class="iris-partner-header">
                <div class="iris-partner-name">{p.label}</div>
                <div class="iris-partner-code">{p.code}</div>
              </div>
              <div class="iris-partner-value">{p.value_now}</div>
              <div class={`iris-partner-delta is-${p.dir}`}>
                {p.yoy_pct} <span class="iris-partner-delta-abs">({p.delta_value})</span>
              </div>
              <div class="iris-partner-share">{p.share_pct} of total EU27 extra-EU exports</div>
              {p.top_chapters.length > 0 && (
                <ul class="iris-partner-chapters">
                  {p.top_chapters.map((c: any) => (
                    <li>
                      <span class="iris-partner-chapter-label">{c.label}</span>
                      <span class="iris-partner-chapter-value">
                        {c.value_now}
                        {c.yoy_pct && <em> ({c.yoy_pct})</em>}
                      </span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="iris-panel">
          <p>Partner drill-down data unavailable for this edition.</p>
        </div>
      )}

      {hasImpWaterfall && (
        <figure class="iris-chart iris-chart--wide iris-chart--tall">
          <figcaption class="iris-chart-caption">
            Imports drill-down, top CN 8-digit codes explain the month's movement. Bars show each
            product's contribution to the net change; the tallest bars carry the causal weight.
          </figcaption>
          <button class="iris-chart-zoom" type="button" aria-label="Zoom"
                  data-chart-src={chartUrl('trade_imports_waterfall_cn8')}
                  data-chart-title="Imports drill-down, top CN 8-digit contributions (waterfall)">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4"/></svg>
          </button>
          <img src={chartUrl('trade_imports_waterfall_cn8')} alt="Imports waterfall, CN 8-digit" />
        </figure>
      )}
    </section>
  </main>

  <script is:inline>
    (function () {
      const burger = document.getElementById('iris-burger');
      const drawer = document.getElementById('iris-drawer');
      const scrim  = document.getElementById('iris-drawer-scrim');
      const closeBtn = document.getElementById('iris-drawer-close');
      if (!drawer || !scrim) return;

      const open  = () => { drawer.setAttribute('data-open', 'true'); scrim.setAttribute('data-open', 'true'); drawer.setAttribute('aria-hidden', 'false'); };
      const close = () => { drawer.setAttribute('data-open', 'false'); scrim.setAttribute('data-open', 'false'); drawer.setAttribute('aria-hidden', 'true'); };

      burger?.addEventListener('click', open);
      closeBtn?.addEventListener('click', close);
      scrim.addEventListener('click', close);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

      const drawerItems = drawer.querySelectorAll('.iris-drawer-item[data-view]');
      const tabs        = document.querySelectorAll('.iris-view-tab[data-view]');
      const views       = document.querySelectorAll('.iris-view[data-view]');

      const switchView = (target) => {
        [...drawerItems, ...tabs].forEach(el => {
          if (el.getAttribute('data-view') === target) el.setAttribute('data-active', 'true');
          else el.removeAttribute('data-active');
        });
        views.forEach(v => {
          if (v.getAttribute('data-view') === target) v.setAttribute('data-active', 'true');
          else v.removeAttribute('data-active');
        });
      };

      drawerItems.forEach(btn => btn.addEventListener('click', () => { switchView(btn.getAttribute('data-view')); close(); }));
      tabs.forEach(btn => btn.addEventListener('click', () => { switchView(btn.getAttribute('data-view')); }));
    })();
  </script>
</Layout>
