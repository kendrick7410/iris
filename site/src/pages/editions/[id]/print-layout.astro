---
/**
 * Print layout for an edition. Drives the PDF export via Playwright
 * (`scripts/generate-pdfs.mjs`). Consumes the same `loadEditionData()`
 * helper as the dashboard, so the printed pages are guaranteed to mirror
 * the live site.
 *
 * Cefic visual identity (April 2021 guidelines): Light Blue digital
 * gradient on the cover, the Notch (white logo cartouche), Noto Serif
 * for headings, Lato for body, sentence case throughout, hex pattern
 * filigrane on the cover.
 */
import '../../../styles/cefic-tokens.css';
import '../../../styles/print.css';
import { getCollection, render } from 'astro:content';
import {
  loadEditionData,
  fmtMonth,
  inlineMd,
} from '../../../lib/edition-data';

export async function getStaticPaths() {
  const editions = await getCollection('editions');
  return editions.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const data = loadEditionData(entry);
const {
  monthName: monthNameFull,
  monthShort: monthShortFmt,
  headlineSection,
  macroProseSections,
  tradeProseSections,
  trajectorySection,
  overviewTitle,
  macroTitle,
  drilldownTitle,
  kpis,
  partnerCards,
  countryPerf,
  maxMag,
  outputSpark,
  pricesSpark,
  salesSpark,
  balance60m,
  partners60m,
  waterfallUsImp,
  waterfallCnImp,
} = data;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{`Iris, ${monthNameFull}, print layout`}</title>
</head>
<body class="iris-print-body">

  <!-- ===== COVER ===== -->
  <section class="print-page print-cover">
    <div class="print-cover-gradient" aria-hidden="true"></div>
    <div class="print-cover-pattern" aria-hidden="true"></div>

    <div class="print-cover-notch" aria-hidden="true">
      <img src="/cefic-logo.png" alt="" />
    </div>

    <div class="print-cover-head">
      <div class="print-cover-eyebrow">A Cefic publication</div>
      <div class="print-cover-brand-mark">Iris<span class="print-cover-brand-dot">.</span></div>
      <div class="print-cover-tagline">Monthly Chemical Trends</div>
    </div>

    <div class="print-cover-body">
      <div class="print-cover-edition">Edition</div>
      <h1 class="print-cover-month">{monthNameFull}</h1>
      <div class="print-cover-meta">
        <span>Published {entry.data.publication_date}</span>
        <span>Reference month: {monthNameFull}</span>
      </div>
    </div>

    <div class="print-cover-foot">
      Data: Eurostat, Comext. © {new Date().getFullYear()} Cefic, European Chemical Industry Council.
    </div>
  </section>

  <!-- ===== OVERVIEW ===== -->
  <section class="print-page print-break print-content-page">
    <header class="print-section-header">
      <div class="print-eyebrow">Overview</div>
      <h2 class="print-section-title">{overviewTitle}</h2>
      <div class="print-section-subtitle">Published {entry.data.publication_date}</div>
    </header>

    {kpis.length > 0 && (
      <div class="print-kpi-grid">
        {kpis.map((k) => (
          <div class="print-kpi">
            <div class="print-kpi-label">{k.label}</div>
            <div class="print-kpi-value">{k.value}</div>
            <div class={`print-kpi-delta is-${k.dir}`}>{k.delta}</div>
            <div class="print-kpi-foot">{k.foot}</div>
          </div>
        ))}
      </div>
    )}

    {balance60m && (
      <figure class="print-chart">
        <figcaption class="print-chart-caption">
          EU27 chemical trade balance, 60-month context.
        </figcaption>
        <svg viewBox={`0 0 ${balance60m.W} ${balance60m.H}`} xmlns="http://www.w3.org/2000/svg" class="print-chart-svg">
          {balance60m.yTicks.map((t: any) => (
            <>
              <line x1={balance60m.padL} x2={balance60m.W - balance60m.padR} y1={t.y} y2={t.y}
                    stroke="#eee" stroke-width="1" stroke-dasharray="2 3" />
              <text x={balance60m.padL - 6} y={t.y + 3} text-anchor="end"
                    font-size="9" fill="#666">{t.v.toFixed(1)}</text>
            </>
          ))}
          <line x1={balance60m.padL} x2={balance60m.W - balance60m.padR}
                y1={balance60m.zeroY} y2={balance60m.zeroY}
                stroke="#1a1a1a" stroke-width="1.2" />
          <path d={`${balance60m.d} L ${balance60m.pts[balance60m.pts.length - 1].x} ${balance60m.zeroY} L ${balance60m.pts[0].x} ${balance60m.zeroY} Z`}
                fill="#00A99E" opacity="0.18" />
          <path d={balance60m.d} fill="none" stroke="#F47B20" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round" />
          <circle cx={balance60m.pts[balance60m.pts.length - 1].x}
                  cy={balance60m.pts[balance60m.pts.length - 1].y}
                  r="4" fill="#F47B20" stroke="#fff" stroke-width="1.5" />
          {balance60m.xTicks.map(({ i, period }: any) => (
            <text x={balance60m.padL + (i / (balance60m.pts.length - 1)) * balance60m.w}
                  y={balance60m.H - 12} text-anchor="middle"
                  font-size="9" fill="#666">{fmtMonth(period)}</text>
          ))}
        </svg>
      </figure>
    )}

    {headlineSection && (
      <div class="print-takeaway">
        <h3 class="print-takeaway-title">Key takeaway</h3>
        {headlineSection.paragraphs.map((p: string) => (
          <p set:html={inlineMd(p)} />
        ))}
      </div>
    )}
  </section>

  <!-- ===== MACRO BRIEF ===== -->
  <section class="print-page print-break print-content-page">
    <header class="print-section-header">
      <div class="print-eyebrow">Macro brief</div>
      <h2 class="print-section-title">{macroTitle}</h2>
      <div class="print-section-subtitle">Production, prices, sales</div>
    </header>

    <div class="print-charts-row">
      {[
        { spark: outputSpark, label: 'Output index, EU27 chemicals' },
        { spark: pricesSpark, label: 'Producer prices, EU27 chemicals' },
        { spark: salesSpark,  label: 'Chemical sales, EU27' },
      ].map(({ spark, label }) => spark && (
        <figure class="print-chart print-chart--third">
          <figcaption class="print-chart-caption">{label} (2021=100)</figcaption>
          <svg viewBox={`0 0 ${spark.W} ${spark.H}`} xmlns="http://www.w3.org/2000/svg" class="print-chart-svg">
            {spark.yTicks.map((t: any) => (
              <>
                <line x1={spark.padL} x2={spark.W - spark.padR} y1={t.y} y2={t.y}
                      stroke="#eee" stroke-width="1" stroke-dasharray="2 3" />
                <text x={spark.padL - 6} y={t.y + 3} text-anchor="end"
                      font-size="8" fill="#888">{t.v.toFixed(0)}</text>
              </>
            ))}
            <path d={spark.areaD} fill={spark.stroke} opacity="0.1" />
            <path d={spark.d} fill="none" stroke={spark.stroke} stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round" />
            {spark.pts.map((p: any, i: number) => (
              <circle cx={p.x} cy={p.y} r={i === spark.pts.length - 1 ? 3.5 : 1.5}
                      fill={spark.stroke} stroke="#fff" stroke-width={i === spark.pts.length - 1 ? 1.2 : 0} />
            ))}
            {spark.xTicks.map((p: any) => (
              <text x={spark.padL + (p.i / (spark.pts.length - 1)) * spark.w}
                    y={spark.H - 8} text-anchor="middle"
                    font-size="8" fill="#888">{fmtMonth(p.period)}</text>
            ))}
          </svg>
          <div class="print-chart-deltapill">
            <span class="print-chart-value">{spark.last.toFixed(1)}</span>
            <span class={`print-chart-delta is-${spark.deltaPct >= 0 ? 'pos' : 'neg'}`}>
              {spark.deltaPct >= 0 ? '+' : ''}{spark.deltaPct.toFixed(1)}% since {fmtMonth(spark.periodStart)}
            </span>
          </div>
        </figure>
      ))}
    </div>

    <div class="print-cols">
      {macroProseSections.length > 0 && (
        <div class="print-panel">
          <h3 class="print-panel-title">Sector context</h3>
          {macroProseSections.map((s) => (
            <div class="print-mdx-block">
              <div class="print-mdx-eyebrow">{s.title}</div>
              {s.paragraphs.slice(0, 1).map((p: string) => (
                <p set:html={inlineMd(p)} />
              ))}
            </div>
          ))}
        </div>
      )}

      {countryPerf.length > 0 && (
        <div class="print-panel">
          <h3 class="print-panel-title">Country output, YoY</h3>
          <ul class="print-bar-list">
            {countryPerf.map((c) => {
              const pct = (Math.abs(c.value) / maxMag) * 100;
              const neg = c.value < 0;
              return (
                <li>
                  <span class="print-bar-label">{c.label}</span>
                  <span class="print-bar-track">
                    <span class={`print-bar-fill ${neg ? 'is-neg' : ''}`} style={`width:${pct}%`}></span>
                  </span>
                  <span class="print-bar-value">{c.value > 0 ? '+' : ''}{c.value.toFixed(1)}%</span>
                </li>
              );
            })}
          </ul>
        </div>
      )}
    </div>

    {trajectorySection && (
      <div class="print-scatter-panel print-break">
        <h3 class="print-panel-title">{trajectorySection.title}</h3>
        <div class="print-scatter-body">
          <div class="print-scatter-prose">
            {trajectorySection.paragraphs.map((p: string) => (
              <p set:html={inlineMd(p)} />
            ))}
            {trajectorySection.source && (
              <p class="print-scatter-source">{trajectorySection.source}</p>
            )}
          </div>
          {trajectorySection.images[0] && (
            <figure class="print-scatter-figure">
              <img src={trajectorySection.images[0].src} alt={trajectorySection.images[0].alt} />
            </figure>
          )}
        </div>
      </div>
    )}
  </section>

  <!-- ===== DRILL-DOWN ===== -->
  <section class="print-page print-break print-content-page">
    <header class="print-section-header">
      <div class="print-eyebrow">Drill-down</div>
      <h2 class="print-section-title">{drilldownTitle}</h2>
      <div class="print-section-subtitle">United States · China · United Kingdom</div>
    </header>

    {partners60m && (
      <figure class="print-chart">
        <figcaption class="print-chart-caption">
          EU27 chemical exports by partner, 60-month context.
        </figcaption>
        <svg viewBox={`0 0 ${partners60m.W} ${partners60m.H}`} xmlns="http://www.w3.org/2000/svg" class="print-chart-svg">
          {partners60m.yTicks.map((t: any) => (
            <>
              <line x1={partners60m.padL} x2={partners60m.W - partners60m.padR} y1={t.y} y2={t.y}
                    stroke="#eee" stroke-width="1" stroke-dasharray="2 3" />
              <text x={partners60m.padL - 6} y={t.y + 3} text-anchor="end"
                    font-size="9" fill="#666">{t.v.toFixed(1)}</text>
            </>
          ))}
          <g class="print-partner-legend">
            {partners60m.partners.map((p: any, i: number) => (
              <>
                <line x1={partners60m.padL + i * 140} x2={partners60m.padL + i * 140 + 16}
                      y1={20} y2={20} stroke={p.color} stroke-width="2.5" />
                <text x={partners60m.padL + i * 140 + 22} y={24}
                      font-size="9" fill="#1a1a1a">{p.label}</text>
              </>
            ))}
          </g>
          {partners60m.partners.map((p: any) => (
            <path d={p.d} fill="none" stroke={p.color} stroke-width={p.weight}
                  stroke-linecap="round" stroke-linejoin="round" />
          ))}
          {partners60m.partners.map((p: any) =>
            p.current && (
              <circle cx={p.current.x} cy={p.current.y} r="4" fill={p.color}
                      stroke="#fff" stroke-width="1.5" />
            )
          )}
          {partners60m.xTicks.map(({ i, period }: any) => (
            <text x={partners60m.padL + (i / (partners60m.periods - 1)) * partners60m.w}
                  y={partners60m.H - 14} text-anchor="middle"
                  font-size="9" fill="#666">{fmtMonth(period)}</text>
          ))}
        </svg>
      </figure>
    )}

    {partnerCards.length > 0 && (
      <div class="print-partner-grid">
        {partnerCards.map((p) => (
          <div class="print-partner-card">
            <div class="print-partner-head">
              <span class="print-partner-label">{p.label}</span>
              <span class="print-partner-code">{p.code}</span>
            </div>
            <div class="print-partner-value">{p.value_now}</div>
            <div class={`print-partner-delta is-${p.dir}`}>
              {p.yoy_pct} <span class="print-partner-abs">({p.delta_value})</span>
            </div>
            <div class="print-partner-share">{p.share_pct} of total exports</div>
            {p.top_chapters.length > 0 && (
              <ul class="print-partner-chapters">
                {p.top_chapters.map((c) => (
                  <li>
                    <span class="print-partner-chapter-label">{c.label}</span>
                    <span class="print-partner-chapter-value">
                      {c.value_now}{c.yoy_pct && <em> ({c.yoy_pct})</em>}
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    )}

    {(waterfallUsImp || waterfallCnImp) && (
      <div class="print-waterfall-row print-break">
        {[
          { spec: waterfallUsImp, country: 'United States', code: 'US' },
          { spec: waterfallCnImp, country: 'China',         code: 'CN' },
        ].map(({ spec, country, code }) => spec && (
          <figure class="print-chart print-chart--half">
            <figcaption class="print-chart-caption">
              <strong>Imports from {country}</strong>, CN 8-digit contributions to the year-on-year change.
            </figcaption>
            <svg viewBox={`0 0 ${spec.W} ${spec.H}`} xmlns="http://www.w3.org/2000/svg" class="print-chart-svg">
              <line x1={spec.padL} x2={spec.W - spec.padR}
                    y1={spec.zeroY} y2={spec.zeroY} stroke="#1a1a1a" stroke-width="0.8" />
              {spec.bars.map((b: any) => (
                <g>
                  <rect x={b.x} y={b.y} width={b.width}
                        height={Math.max(b.height, 1)} fill={b.color}
                        opacity={b.kind === 'other' ? 0.6 : 0.92} rx="2" />
                  <text x={b.cx} y={b.y - 4} text-anchor="middle"
                        font-size="9" font-weight="600" fill={b.color}>
                    {b.kind === 'start' || b.kind === 'end'
                      ? `€${(b.value || 0).toFixed(2)}`
                      : `${(b.delta ?? 0) >= 0 ? '+' : ''}${(b.delta ?? 0).toFixed(2)}`}
                  </text>
                  <text x={b.cx} y={spec.H - spec.padB + 14}
                        text-anchor="end" font-size="8" fill="#666"
                        transform={`rotate(-30, ${b.cx}, ${spec.H - spec.padB + 14})`}>
                    {(b.short || b.label).length > 28
                      ? (b.short || b.label).slice(0, 26) + '…'
                      : (b.short || b.label)}
                  </text>
                </g>
              ))}
            </svg>
            <div class="print-waterfall-summary">
              Net change:&nbsp;
              <strong class={spec.totalDelta >= 0 ? 'is-pos' : 'is-neg'}>
                {spec.totalDelta >= 0 ? '+' : ''}€{spec.totalDelta.toFixed(2)} bn
              </strong>
              <span class="print-waterfall-summary-pct">
                &nbsp;({((spec.totalDelta / spec.bars[0].value) * 100).toFixed(1)}% YoY)
              </span>
            </div>
          </figure>
        ))}
      </div>
    )}

    {tradeProseSections.length > 0 && (
      <div class="print-panel print-trade-context print-break">
        <h3 class="print-panel-title">Trade context</h3>
        {tradeProseSections.map((s) => (
          <div class="print-mdx-block">
            <div class="print-mdx-eyebrow">{s.title}</div>
            {s.paragraphs.map((p: string) => (
              <p set:html={inlineMd(p)} />
            ))}
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- ===== SOURCES & METHODOLOGY ===== -->
  <section class="print-page print-break print-content-page">
    <header class="print-section-header">
      <div class="print-eyebrow">Sources and methodology</div>
      <h2 class="print-section-title">How this edition was built</h2>
    </header>
    <div class="print-narrative">
      <p><strong>Data source.</strong> Eurostat Short-Term Business Statistics (production, prices,
        turnover), seasonally adjusted where available. Trade flows from Comext (EU27 external
        trade), extra-EU only, declarant=EU, flow exports=2 and imports=1.</p>
      <p><strong>Scope.</strong> NACE C20 chemicals for industrial indicators; Comext chapters
        28-39 filtered by the Cefic chemistry product map for trade.</p>
      <p><strong>Window conventions.</strong> YoY (year-on-year), YTD (year-to-date, first N
        months of the current year vs the same window of the prior year), pre-crisis baseline
        averages 2014-2019. Index base: 2021=100 unless otherwise stated.</p>
      <p><strong>Anomalies.</strong> When the comparison base is distorted (Z-score above 2σ
        against the 12-month rolling mean, or bilateral concentration above 75% of the absolute
        variation), the section carries an explicit base-effect caveat.</p>
      <p><strong>Publication.</strong> Iris is a monthly Cefic publication. Past editions and
        full methodology at iris.cefic.org.</p>
    </div>
  </section>

</body>
</html>
