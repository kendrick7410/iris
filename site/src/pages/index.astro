---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const editions = await getCollection('editions');
const sorted = editions.sort((a, b) => b.id.localeCompare(a.id));

const monthName = (id: string) => {
  const [y, m] = id.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
};
const monthShort = (id: string) => {
  const [y, m] = id.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
};

// Extract first H2 headline + first paragraph from raw MDX
const contentRoot = path.resolve('src/content/editions');
const readSummary = (id: string): { headline: string; excerpt: string } => {
  try {
    const raw = fs.readFileSync(path.join(contentRoot, `${id}.mdx`), 'utf8');
    const body = raw.replace(/^---[\s\S]*?---/, '').trim();
    const h2Match = body.match(/^##\s+(.+)$/m);
    const headline = h2Match ? h2Match[1].trim() : `Edition ${id}`;
    const afterH2 = h2Match ? body.slice(body.indexOf(h2Match[0]) + h2Match[0].length) : body;
    const paraMatch = afterH2.trim().match(/^([^\n#][^\n]*(?:\n[^\n#][^\n]*)*)/);
    const excerpt = paraMatch ? paraMatch[1].trim().replace(/\s+/g, ' ').slice(0, 240) + (paraMatch[1].length > 240 ? '…' : '') : '';
    return { headline, excerpt };
  } catch {
    return { headline: `Edition ${id}`, excerpt: '' };
  }
};

const featured = sorted[0];
const rest     = sorted.slice(1);
const featuredSummary = featured ? readSummary(featured.id) : null;

const thumbVariants = ['', '--orange', '--green', '--blue'];

// Cadence is monthly; the next edition's expected publication date is the
// previous one shifted by ~one month. The site stays a full week ahead of
// the actual cron run (Tuesday 09:00, --month M-2), so this is an estimate
// rather than a guarantee.
const formatLongDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const formatShortMonth = (id: string) => {
  const [y, m] = id.split('-');
  return `${m}/${y}`;
};

let lastEditionLabel: string | null = null;
let nextEditionLabel: string | null = null;
let referenceMonthLabel: string | null = null;
let featuredPdfUrl: string | null = null;
let featuredPdfName: string | null = null;
if (featured) {
  lastEditionLabel = formatShortMonth(featured.id);
  referenceMonthLabel = monthName(featured.id);
  const lastPub = new Date(featured.data.publication_date);
  if (!Number.isNaN(lastPub.getTime())) {
    const next = new Date(lastPub);
    next.setMonth(next.getMonth() + 1);
    nextEditionLabel = formatLongDate(next);
  }
  // The CI deploy pipeline always generates a PDF per edition, so we
  // unconditionally surface the download link. Local dev without
  // `npm run pdf:all` will 404 the link — acceptable trade-off.
  featuredPdfUrl = `/downloads/${featured.id}.pdf`;
  featuredPdfName = `Iris-${monthName(featured.id).replace(' ', '-')}.pdf`;
}

// Subscribe destination — kept as a single constant so the Cefic team can
// swap the address (or a form URL) without touching the markup.
const SUBSCRIBE_HREF = 'mailto:iris@cefic.org?subject=Subscribe%20to%20Iris%20updates&body=Please%20add%20me%20to%20the%20Iris%20release%20notification%20list.';
---
<Layout
  title="Iris: Monthly Chemical Trends | Cefic"
  variant="landing"
  heroOverlap
>
  <section class="iris-hero">
    <div class="iris-hero-inner">
      <div class="iris-hero-eyebrow">A Cefic publication</div>
      <h1>Iris<em>.</em></h1>
      <p class="iris-hero-tagline">
        Delivering clarity to the chemical industry.
      </p>
      <div class="iris-hero-meta">
        <div>
          <span class="iris-hero-meta-label">Cadence</span>
          <span class="iris-hero-meta-value">Monthly</span>
        </div>
        <div>
          <span class="iris-hero-meta-label">Source</span>
          <span class="iris-hero-meta-value">Eurostat · Comext</span>
        </div>
        <div>
          <span class="iris-hero-meta-label">Latest</span>
          <span class="iris-hero-meta-value">{featured ? monthShort(featured.id) : '-'}</span>
        </div>
        <div>
          <span class="iris-hero-meta-label">Editions</span>
          <span class="iris-hero-meta-value">{sorted.length}</span>
        </div>
      </div>
    </div>
    <div class="iris-hero-scroll">Scroll</div>
  </section>

  {featured && featuredSummary && (
    <section class="iris-section">
      <div class="iris-section-header">
        <div>
          <div class="iris-section-eyebrow">Latest edition</div>
          <h2 class="iris-section-title">{monthName(featured.id)}</h2>
        </div>
        <a class="iris-section-link" href={`/editions/${featured.id}`}>Read edition →</a>
      </div>
      <article class="iris-featured">
        <div class="iris-featured-media">
          <div>
            <div class="iris-featured-label">Published {featured.data.publication_date}</div>
          </div>
          <div class="iris-featured-month">{monthShort(featured.id)}</div>
        </div>
        <div class="iris-featured-body">
          <div>
            <h3 class="iris-featured-title">{featuredSummary.headline}</h3>
            {featuredSummary.excerpt && <p class="iris-featured-excerpt">{featuredSummary.excerpt}</p>}
          </div>
          <a class="iris-featured-cta" href={`/editions/${featured.id}`}>Open dashboard</a>
        </div>
      </article>

      {lastEditionLabel && nextEditionLabel && (
        <aside class="iris-release-strip" aria-label="Iris release schedule">
          <div class="iris-release-strip-cell">
            <span class="iris-release-strip-label">Last version available</span>
            <div class="iris-release-strip-value-row">
              <span class="iris-release-strip-value">{lastEditionLabel}</span>
              {featuredPdfUrl && featuredPdfName && (
                <a class="iris-release-strip-pdf" href={featuredPdfUrl}
                   download={featuredPdfName} aria-label="Download the latest edition as PDF">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor"
                       stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 2v9M4 7l4 4 4-4M2 14h12" />
                  </svg>
                  <span>PDF</span>
                </a>
              )}
            </div>
          </div>
          {referenceMonthLabel && (
            <div class="iris-release-strip-cell">
              <span class="iris-release-strip-label">Reference month</span>
              <span class="iris-release-strip-value">{referenceMonthLabel}</span>
            </div>
          )}
          <div class="iris-release-strip-cell">
            <span class="iris-release-strip-label">Next version expected</span>
            <span class="iris-release-strip-value">{nextEditionLabel}</span>
          </div>
          <a class="iris-release-strip-subscribe" href={SUBSCRIBE_HREF}>
            Subscribe to release updates →
          </a>
        </aside>
      )}
    </section>
  )}

  {rest.length > 0 && (
    <section class="iris-section">
      <div class="iris-section-header">
        <div>
          <div class="iris-section-eyebrow">Archive</div>
          <h2 class="iris-section-title">All editions</h2>
        </div>
      </div>
      <ul class="iris-editions-grid">
        {rest.map((e, i) => {
          const { headline } = readSummary(e.id);
          const variant = thumbVariants[(i + 1) % thumbVariants.length];
          return (
            <li class="iris-edition-card">
              <a href={`/editions/${e.id}`}>
                <div class={`iris-edition-thumb iris-edition-thumb${variant}`}>
                  <span class="iris-edition-thumb-month">{monthShort(e.id)}</span>
                </div>
                <div class="iris-edition-meta">
                  <span class="iris-edition-meta-date">{e.data.publication_date}</span>
                  <h3 class="iris-edition-meta-title">{headline}</h3>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <section class="iris-section">
    <div class="iris-section-header">
      <div>
        <div class="iris-section-eyebrow">About</div>
        <h2 class="iris-section-title">What Iris is</h2>
      </div>
    </div>
    <div class="iris-pitch">
      <div class="iris-pitch-body">
        <p>
          Iris turns the raw statistical pulse of European chemistry (<strong>production indices, producer prices, trade flows</strong>)
          into a monthly narrative. Each edition opens with a macro brief, drills into the products, partners and sectors
          that moved the needle, and closes with a retrospective check against prior reads.
        </p>
      </div>
      <div class="iris-pitch-stats">
        <div>
          <div class="iris-pitch-stat-value">27</div>
          <div class="iris-pitch-stat-label">EU member states tracked every month</div>
        </div>
        <div>
          <div class="iris-pitch-stat-value">~1,400</div>
          <div class="iris-pitch-stat-label">CN8 product codes in the Comext cube</div>
        </div>
        <div>
          <div class="iris-pitch-stat-value">2014</div>
          <div class="iris-pitch-stat-label">Baseline reference period for pre-crisis comparisons</div>
        </div>
        <div>
          <div class="iris-pitch-stat-value">T+6w</div>
          <div class="iris-pitch-stat-label">Typical lag between reference month and publication</div>
        </div>
      </div>
    </div>
  </section>

  <section class="iris-section iris-methodology-teaser">
    <div class="iris-section-header">
      <div>
        <div class="iris-section-eyebrow">Data and methodology</div>
        <h2 class="iris-section-title">How Iris is built</h2>
      </div>
      <a class="iris-section-link" href="/methodology">Read the methodology →</a>
    </div>
    <div class="iris-teaser-body">
      <p>
        Iris is reproducible from public Eurostat data end-to-end. Behind every figure on the
        site lives a precise filter, a documented calculation, and a scheduled pipeline step.
      </p>
      <ul class="iris-teaser-bullets">
        <li><strong>Data sources</strong> — Eurostat STS (<code>sts_inpr_m</code>, <code>sts_inppd_m</code>, <code>sts_intv_m</code>) and Comext, with exact filters.</li>
        <li><strong>Classifications</strong> — NACE Rev. 2 (C20 strict, peer benchmarks C/C21/C24/C29), CPA 2015, Combined Nomenclature (1,372 CN8 codes).</li>
        <li><strong>Calculations</strong> — YoY, YTD, pre-crisis baseline, partner drill-down, Pareto concentration, base-effect guards.</li>
        <li><strong>Pipeline</strong> — seven steps from Eurostat fetch to Azure deployment, with scheduled jobs and selective regeneration.</li>
        <li><strong>Editorial engine</strong> — 500-line Cefic style guide with quality-gated LLM drafting.</li>
      </ul>
      <a class="iris-featured-cta" href="/methodology">Open the full methodology</a>
    </div>
  </section>
</Layout>
