---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const editions = await getCollection('editions');
const sorted = editions.sort((a, b) => b.id.localeCompare(a.id));

const monthName = (id: string) => {
  const [y, m] = id.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
};
const monthShort = (id: string) => {
  const [y, m] = id.split('-');
  const d = new Date(Number(y), Number(m) - 1, 1);
  return d.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
};

// Extract first H2 headline + first paragraph from raw MDX
const contentRoot = path.resolve('src/content/editions');
const readSummary = (id: string): { headline: string; excerpt: string } => {
  try {
    const raw = fs.readFileSync(path.join(contentRoot, `${id}.mdx`), 'utf8');
    const body = raw.replace(/^---[\s\S]*?---/, '').trim();
    const h2Match = body.match(/^##\s+(.+)$/m);
    const headline = h2Match ? h2Match[1].trim() : `Edition ${id}`;
    const afterH2 = h2Match ? body.slice(body.indexOf(h2Match[0]) + h2Match[0].length) : body;
    const paraMatch = afterH2.trim().match(/^([^\n#][^\n]*(?:\n[^\n#][^\n]*)*)/);
    const excerpt = paraMatch ? paraMatch[1].trim().replace(/\s+/g, ' ').slice(0, 240) + (paraMatch[1].length > 240 ? '…' : '') : '';
    return { headline, excerpt };
  } catch {
    return { headline: `Edition ${id}`, excerpt: '' };
  }
};

const featured = sorted[0];
const rest     = sorted.slice(1);
const featuredSummary = featured ? readSummary(featured.id) : null;

const thumbVariants = ['', '--orange', '--green', '--blue'];
---
<Layout
  title="Iris: Monthly Chemical Trends | Cefic"
  variant="landing"
  heroOverlap
>
  <section class="iris-hero">
    <div class="iris-hero-inner">
      <div class="iris-hero-eyebrow">A Cefic publication</div>
      <h1>Iris<em>.</em></h1>
      <p class="iris-hero-tagline">
        Delivering clarity to the chemical industry.
      </p>
      <div class="iris-hero-meta">
        <div>
          <span class="iris-hero-meta-label">Cadence</span>
          <span class="iris-hero-meta-value">Monthly</span>
        </div>
        <div>
          <span class="iris-hero-meta-label">Source</span>
          <span class="iris-hero-meta-value">Eurostat · Comext</span>
        </div>
        <div>
          <span class="iris-hero-meta-label">Latest</span>
          <span class="iris-hero-meta-value">{featured ? monthShort(featured.id) : '-'}</span>
        </div>
        <div>
          <span class="iris-hero-meta-label">Editions</span>
          <span class="iris-hero-meta-value">{sorted.length}</span>
        </div>
      </div>
    </div>
    <div class="iris-hero-scroll">Scroll</div>
  </section>

  {featured && featuredSummary && (
    <section class="iris-section">
      <div class="iris-section-header">
        <div>
          <div class="iris-section-eyebrow">Latest edition</div>
          <h2 class="iris-section-title">{monthName(featured.id)}</h2>
        </div>
        <a class="iris-section-link" href={`/editions/${featured.id}`}>Read edition →</a>
      </div>
      <article class="iris-featured">
        <div class="iris-featured-media">
          <div>
            <div class="iris-featured-label">Published {featured.data.publication_date}</div>
          </div>
          <div class="iris-featured-month">{monthShort(featured.id)}</div>
        </div>
        <div class="iris-featured-body">
          <div>
            <h3 class="iris-featured-title">{featuredSummary.headline}</h3>
            {featuredSummary.excerpt && <p class="iris-featured-excerpt">{featuredSummary.excerpt}</p>}
          </div>
          <a class="iris-featured-cta" href={`/editions/${featured.id}`}>Open dashboard</a>
        </div>
      </article>
    </section>
  )}

  {rest.length > 0 && (
    <section class="iris-section">
      <div class="iris-section-header">
        <div>
          <div class="iris-section-eyebrow">Archive</div>
          <h2 class="iris-section-title">All editions</h2>
        </div>
      </div>
      <ul class="iris-editions-grid">
        {rest.map((e, i) => {
          const { headline } = readSummary(e.id);
          const variant = thumbVariants[(i + 1) % thumbVariants.length];
          return (
            <li class="iris-edition-card">
              <a href={`/editions/${e.id}`}>
                <div class={`iris-edition-thumb iris-edition-thumb${variant}`}>
                  <span class="iris-edition-thumb-month">{monthShort(e.id)}</span>
                </div>
                <div class="iris-edition-meta">
                  <span class="iris-edition-meta-date">{e.data.publication_date}</span>
                  <h3 class="iris-edition-meta-title">{headline}</h3>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <section class="iris-section">
    <div class="iris-section-header">
      <div>
        <div class="iris-section-eyebrow">About</div>
        <h2 class="iris-section-title">What Iris is</h2>
      </div>
    </div>
    <div class="iris-pitch">
      <div class="iris-pitch-body">
        <p>
          Iris turns the raw statistical pulse of European chemistry (<strong>production indices, producer prices, trade flows</strong>)
          into a monthly narrative. Each edition opens with a macro brief, drills into the products, partners and sectors
          that moved the needle, and closes with a retrospective check against prior reads.
        </p>
      </div>
      <div class="iris-pitch-stats">
        <div>
          <div class="iris-pitch-stat-value">27</div>
          <div class="iris-pitch-stat-label">EU member states tracked every month</div>
        </div>
        <div>
          <div class="iris-pitch-stat-value">~1,400</div>
          <div class="iris-pitch-stat-label">CN8 product codes in the Comext cube</div>
        </div>
        <div>
          <div class="iris-pitch-stat-value">2014</div>
          <div class="iris-pitch-stat-label">Baseline reference period for pre-crisis comparisons</div>
        </div>
        <div>
          <div class="iris-pitch-stat-value">T+6w</div>
          <div class="iris-pitch-stat-label">Typical lag between reference month and publication</div>
        </div>
      </div>
    </div>
  </section>

  <section class="iris-section iris-methodology">
    <div class="iris-section-header">
      <div>
        <div class="iris-section-eyebrow">Data and methodology</div>
        <h2 class="iris-section-title">How Iris is built</h2>
      </div>
    </div>

    <div class="iris-methodology-intro">
      <p>
        Iris is reproducible from public Eurostat data end-to-end. The sections below list
        every input series, the calculations that turn them into indicators, the pipeline
        that drafts and publishes the edition, and the editorial rules that govern the prose.
      </p>
    </div>

    <h3 class="iris-methodology-h3">1. Data sources</h3>
    <div class="iris-source-grid">
      <div class="iris-source-card">
        <div class="iris-source-head">
          <h4>Production index</h4>
          <span class="iris-source-code">sts_inpr_m</span>
        </div>
        <div class="iris-source-filters">
          <span><strong>NACE</strong> <code>C20</code> (Chemicals, 2-digit)</span>
          <span><strong>Benchmarks</strong> <code>C</code>, <code>C21</code>, <code>C24</code>, <code>C29</code></span>
          <span><strong>Geo</strong> <code>EU27_2020</code> + 27 states</span>
          <span><strong>Unit</strong> <code>I21</code> (2021 = 100)</span>
          <span><strong>s_adj</strong> <code>SCA</code> (seasonally + working-day adjusted)</span>
        </div>
        <p>
          Monthly index of industrial production. Chemicals only (NACE <code>C20</code>);
          pharmaceuticals (<code>C21</code>), basic metals (<code>C24</code>), motor vehicles
          (<code>C29</code>) pulled as peer-sector benchmarks. Feeds the Output sparkline
          and the per-country YoY bar list in the Macro brief tab.
        </p>
        <a class="iris-source-link"
           href="https://ec.europa.eu/eurostat/databrowser/view/sts_inpr_m__custom_12061884/default/table"
           target="_blank" rel="noopener">
          Eurostat databrowser, sts_inpr_m
          <svg viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3h7v7M13 3L4 12"/></svg>
        </a>
      </div>

      <div class="iris-source-card">
        <div class="iris-source-head">
          <h4>Producer prices</h4>
          <span class="iris-source-code">sts_inppd_m</span>
        </div>
        <div class="iris-source-filters">
          <span><strong>NACE</strong> <code>C20</code></span>
          <span><strong>Market</strong> domestic</span>
          <span><strong>Geo</strong> <code>EU27_2020</code> + 27 states</span>
          <span><strong>Unit</strong> <code>I21</code> (2021 = 100)</span>
        </div>
        <p>
          Monthly index of producer prices in industry (domestic market), NACE
          <code>C20</code>, EU27 aggregate and member states. Feeds the Prices sparkline
          and the country price-decline ranking in trade commentary.
        </p>
        <a class="iris-source-link"
           href="https://ec.europa.eu/eurostat/databrowser/view/sts_inppd_m__custom_12061992/default/table"
           target="_blank" rel="noopener">
          Eurostat databrowser, sts_inppd_m
          <svg viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3h7v7M13 3L4 12"/></svg>
        </a>
      </div>

      <div class="iris-source-card">
        <div class="iris-source-head">
          <h4>Chemical sales (turnover)</h4>
          <span class="iris-source-code">sts_intv_m</span>
        </div>
        <div class="iris-source-filters">
          <span><strong>NACE</strong> <code>C20</code></span>
          <span><strong>Geo</strong> <code>EU27_2020</code> + 27 states</span>
          <span><strong>Unit</strong> <code>I21</code> (2021 = 100)</span>
        </div>
        <p>
          Monthly turnover index in industry, NACE <code>C20</code>. Published with a slightly
          longer lag than production and prices (typically T+7 to T+8 weeks); the macro brief
          flags the lag window when the turnover reference month trails the production reference
          month.
        </p>
        <a class="iris-source-link"
           href="https://ec.europa.eu/eurostat/databrowser/view/sts_intv_m__custom_12062104/default/table"
           target="_blank" rel="noopener">
          Eurostat databrowser, sts_intv_m
          <svg viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3h7v7M13 3L4 12"/></svg>
        </a>
      </div>

      <div class="iris-source-card">
        <div class="iris-source-head">
          <h4>Trade flows (exports/imports)</h4>
          <span class="iris-source-code">Comext</span>
        </div>
        <div class="iris-source-filters">
          <span><strong>Declarant</strong> <code>EU</code> (EU27 as reporter)</span>
          <span><strong>Partner</strong> ≠ <code>EU27</code> (extra-EU only)</span>
          <span><strong>Products</strong> 1,372 CN 8-digit codes</span>
          <span><strong>Flows</strong> 1 = imports, 2 = exports</span>
        </div>
        <p>
          Chemistry filter maps <strong>CPA 2015 → CN 2025</strong> via the Cefic
          <code>SubstanceId.csv</code> lookup. Coverage by NACE 4-digit class:
        </p>
        <ul class="iris-source-nace-list">
          <li><strong>NACE 20.11-20.17</strong> basic chemicals (industrial gases, dyes, inorganic and organic chemicals, fertilisers, primary plastics, synthetic rubber)</li>
          <li><strong>NACE 20.20</strong> pesticides and other agrochemical products</li>
          <li><strong>NACE 20.30</strong> paints, varnishes, printing inks</li>
          <li><strong>NACE 20.41-20.42</strong> soaps, detergents, cleaning and polishing preparations, perfumes</li>
          <li><strong>NACE 20.51-20.59</strong> other chemical products (explosives, glues, essential oils, photographic chemicals)</li>
          <li><strong>NACE 20.60</strong> man-made fibres</li>
          <li><strong>NACE 21.10</strong> basic pharmaceutical products (active pharmaceutical ingredients). <em>NACE 21.20 finished drugs is excluded.</em></li>
        </ul>
        <p>
          Source of the 60-month balance chart, the exports-by-partner chart, the US/CN/GB
          partner cards, and the CN 8-digit waterfall charts.
        </p>
        <a class="iris-source-link"
           href="https://ec.europa.eu/eurostat/web/international-trade-in-goods/data/database"
           target="_blank" rel="noopener">
          Eurostat, Comext database
          <svg viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3h7v7M13 3L4 12"/></svg>
        </a>
      </div>
    </div>

    <p class="iris-methodology-note-inline">
      <strong>Key scope difference.</strong> The industrial-indicator path (production, prices,
      sales) is strict <code>C20</code> and never picks up pharmaceuticals. The trade path reaches
      into <code>21.10</code> because the Cefic chemistry map explicitly includes active pharmaceutical
      ingredients. Expect imports from the United States and China to skew high on polypeptide
      hormones and heterocyclic compounds for that reason.
    </p>

    <h3 class="iris-methodology-h3">2. Classifications</h3>
    <ul class="iris-docs-list">
      <li>
        <strong>NACE Rev. 2</strong> (statistical classification of economic activities).
        Industrial indicators use the 2-digit <strong><code>C20</code> Chemicals</strong>
        division, strict (no pharmaceuticals). Peer-sector benchmarks quoted in prose:
        <code>C</code> (total manufacturing), <code>C21</code> (pharmaceuticals), <code>C24</code>
        (basic metals), <code>C29</code> (motor vehicles).
        <a href="https://ec.europa.eu/eurostat/ramon/nomenclatures/index.cfm?TargetUrl=LST_CLS_DTL&amp;StrNom=NACE_REV2"
           target="_blank" rel="noopener">NACE Rev. 2 reference ↗</a>
      </li>
      <li>
        <strong>CPA 2015</strong> (statistical classification of products by activity).
        The chemistry product map in <code>comext-etl/data/upload/SubstanceId.csv</code> is
        defined in CPA 2015 terms at the 4-digit level (<code>2011</code> to <code>2060</code>,
        plus <code>2110</code> for active pharmaceutical ingredients) and mapped to 2025
        CN 8-digit codes.
        <a href="https://ec.europa.eu/eurostat/ramon/nomenclatures/index.cfm?TargetUrl=LST_NOM_DTL&amp;StrNom=CPA_2015"
           target="_blank" rel="noopener">CPA 2015 reference ↗</a>
      </li>
      <li>
        <strong>Combined Nomenclature (CN 8-digit)</strong>. Used for the Comext trade
        drill-down. Scope spans 1,372 distinct codes across chapters 27-40 (mineral fuels,
        organic and inorganic chemicals, pharmaceutical APIs, fertilisers, essential oils,
        soaps, explosives, plastics, rubber). Labels (for example <em>polypeptide hormones</em>,
        <em>heterocyclic compounds with nitrogen</em>) are pulled from the Comext nomenclature.
        <a href="https://taxation-customs.ec.europa.eu/customs-4/combined-nomenclature-cn_en"
           target="_blank" rel="noopener">Combined Nomenclature ↗</a>
      </li>
      <li>
        <strong>EU27 membership</strong>. Aggregates follow the current EU27 definition
        (<code>geo=EU27_2020</code>, post-Brexit); the UK is treated as a third country across
        the whole history for consistency.
      </li>
    </ul>

    <h3 class="iris-methodology-h3">3. Calculations</h3>
    <div class="iris-calc-grid">
      <div class="iris-calc-card">
        <div class="iris-calc-name">Year-on-year (YoY)</div>
        <code class="iris-calc-formula">(current − previous) ÷ previous × 100</code>
        <p>Current period value against the same period one year earlier. Default window for monthly indicators.</p>
      </div>
      <div class="iris-calc-card">
        <div class="iris-calc-name">Year-to-date (YTD)</div>
        <code class="iris-calc-formula">Σ(first N months of Y) ÷ Σ(first N months of Y-1) − 1</code>
        <p>Used for trade flows where a single-month reading is too noisy. Never mixed with
          single-month figures in the same sentence without an explicit scope prefix (§1.14).</p>
      </div>
      <div class="iris-calc-card">
        <div class="iris-calc-name">Pre-crisis baseline</div>
        <code class="iris-calc-formula">avg(2014 … 2019)</code>
        <p>Six-year average (2014-2019) used to measure the structural gap opened by the 2022
          energy shock. Quoted as "X below pre-crisis levels (2014-2019 average)".</p>
      </div>
      <div class="iris-calc-card">
        <div class="iris-calc-name">Partner drill-down</div>
        <code class="iris-calc-formula">Σ(value_current − value_prev) by CN8</code>
        <p>For US, CN, GB: top 3 positive movers, top 3 negative movers, residual "Other"
          bar so the totals reconcile. Labels from the Comext nomenclature.</p>
      </div>
      <div class="iris-calc-card">
        <div class="iris-calc-name">Pareto concentration</div>
        <code class="iris-calc-formula">top-N cumulative share ≥ 50% of Σ|Δ|</code>
        <p>Triggers the Pareto framing in prose only when concentrated. Flat distributions get
          a chapter-level breakdown instead.</p>
      </div>
      <div class="iris-calc-card">
        <div class="iris-calc-name">Base-effect guards</div>
        <code class="iris-calc-formula">5 signals → severity ∈ &#123;none, watch, warn, critical&#125;</code>
        <p>Trade shock without industrial co-movement, ≤ 2 partners carrying > 75% of the
          variation, comparison base > 2 sigma above its 12-month rolling mean, Δ vs N-2 less
          than half Δ vs N-1, value/volume divergence > 2×. See <code>analysis/anomaly_detector.py</code>.</p>
      </div>
    </div>

    <h3 class="iris-methodology-h3">4. Pipeline</h3>
    <ol class="iris-pipeline">
      <li>
        <span class="iris-pipeline-step">Fetch</span>
        <p>
          Pulls monthly STS series from the Eurostat JSON API for C20 production, prices, and
          turnover, across the EU27 and the 27 member states. Trade data reads from the
          sibling <a href="https://github.com/kendrick7410/comext-etl" target="_blank" rel="noopener">
          comext-etl</a> parquet, already filtered to chemistry (14M+ rows, 2002-present,
          monthly). Raw cache written to <code>data/cache/YYYY-MM/</code>.
        </p>
      </li>
      <li>
        <span class="iris-pipeline-step">Process</span>
        <p>
          Computes YoY, YTD, pre-crisis deltas, per-country and per-sector breakdowns, partner
          drill-downs, 60-month historical series, and the anomaly report. Outputs are fiche
          JSONs in <code>data/processed/YYYY-MM/fiches/</code>, one per section
          (output, prices, sales, trade_exports, trade_imports, macro_brief). Fiches are
          self-contained and drive both the prose drafting and the site rendering.
        </p>
      </li>
      <li>
        <span class="iris-pipeline-step">Draft</span>
        <p>
          Five sections drafted by Claude Sonnet (<code>claude-sonnet-4</code>) with the
          <code>context-prep/editorial/system.md</code> canonical prompt as system message and
          the fiche JSON as user message. Each draft is quality-gated (word count, banned
          connectors, zero em dashes, zero bullets in macro brief); on gate failure the
          request re-runs on Opus (<code>claude-opus-4</code>) and the best of the two is kept.
        </p>
      </li>
      <li>
        <span class="iris-pipeline-step">Macro brief</span>
        <p>
          Step 3.5: the opening headline and 80-120 word paragraph are drafted from the
          already-reconciled sections, under the <code>editorial/prompts/macro_brief.md</code>
          overlay. Anomaly-active mode expands the word ceiling to 150 when a
          base-effect caveat is mandatory.
        </p>
      </li>
      <li>
        <span class="iris-pipeline-step">Visualise</span>
        <p>
          Charts rendered via <code>charts/templates/*.py</code>. Index series and country
          bars use matplotlib SVG; long-arc line charts and waterfalls are rendered inline
          at Astro build time from the fiches, so they scale cleanly in the zoom lightbox
          and accept hover tooltips.
        </p>
      </li>
      <li>
        <span class="iris-pipeline-step">Build</span>
        <p>
          <code>pipelines/monthly_run.py</code> emits the consolidated edition Markdown
          into <code>site/src/content/editions/YYYY-MM.mdx</code>. Astro's static build
          wires charts, fiches, and the MDX body into the dashboard template and the
          print-layout page.
        </p>
      </li>
      <li>
        <span class="iris-pipeline-step">Publish</span>
        <p>
          Commit to <code>main</code> on <a href="https://github.com/kendrick7410/iris" target="_blank" rel="noopener">kendrick7410/iris</a>.
          Azure Static Web Apps watches the repository and redeploys <code>iris.cefic.org</code>
          within 1-2 minutes of the push. The PDF is generated by <code>scripts/generate_pdf.py</code>
          via headless Chromium against the print-layout page and committed alongside the edition.
        </p>
      </li>
    </ol>

    <h3 class="iris-methodology-h3">5. Scheduled jobs</h3>
    <ul class="iris-docs-list">
      <li>
        <strong>Monthly edition run.</strong> The full pipeline fires on Yaghi once
        the Eurostat STS release for month M is available (typically around the 15th of month
        M+2). No fixed cron yet; triggered manually via
        <code>python pipelines/monthly_run.py --month YYYY-MM</code> until the release-watcher
        is wired.
      </li>
      <li>
        <strong>Comext ETL refresh.</strong> Weekly on Monday 06:00 via
        <code>cron_weekly.sh</code> in the sibling repo <a href="https://github.com/kendrick7410/comext-etl" target="_blank" rel="noopener">comext-etl</a>.
        The ETL regenerates <code>comext_export.parquet</code> and pushes the two downstream
        sites (<code>comext-analysis</code> cube and <code>comext-etl-status</code> page), so Iris picks
        up revised trade figures on the next pipeline run.
      </li>
      <li>
        <strong>Selective regeneration.</strong> Three one-shot scripts cover the common
        mid-edition adjustments without replaying the whole pipeline:
        <code>scripts/regen_macro_brief.py YYYY-MM</code> (step 3.5 only),
        <code>scripts/regen_v3.py YYYY-MM</code> (macro brief + trade sections),
        <code>analysis/enrich_fiches.py YYYY-MM</code> (add partner_drilldown and 60-month
        historical series to existing fiches).
      </li>
      <li>
        <strong>PDF refresh.</strong> <code>python scripts/generate_pdf.py --month YYYY-MM</code>
        requires a running Astro dev server on the same host and writes
        <code>site/public/downloads/YYYY-MM.pdf</code>.
      </li>
    </ul>

    <h3 class="iris-methodology-h3">6. Editorial engine</h3>
    <p class="iris-methodology-p">
      All prose is written by an LLM under a 500-line style guide derived from Cefic's
      Facts &amp; Figures and Chemical Trends Reports corpus, synthesised into 24 editorial
      patterns. Twenty MUST rules and a dozen SHOULD rules shape the Iris voice.
    </p>
    <ul class="iris-docs-list">
      <li><strong>§1.13</strong> Anomaly disclosure mandatory when severity ≥ <code>warn</code>. Base-effect caveat placed immediately after the opening finding.</li>
      <li><strong>§1.14</strong> Temporal scope consistency. YTD and single-month figures never juxtaposed in the same sentence without explicit prefix.</li>
      <li><strong>§1.17</strong> Canonical trade triptych. Variation % + absolute level + absolute delta, never condensed into an ambiguous construction.</li>
      <li><strong>§1.18</strong> No em dashes (U+2014). Absolute rule, enforced by the quality gate.</li>
      <li><strong>§1.19</strong> Key-partner symmetry. US / CN / GB covered with at least one dedicated sentence each.</li>
      <li><strong>§1.20</strong> Every chart placeholder is preceded by at least one prose sentence.</li>
      <li><strong>§5.11</strong> Partner drill-down templates (Template A in sections, Template B in macro brief).</li>
      <li><strong>§5.12</strong> CN8 labels truncated at 40-60 chars with the 8-digit code always cited first.</li>
    </ul>

