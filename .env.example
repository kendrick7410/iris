# Iris — environment variables
# Copy this file to .env and fill in the values. Never commit .env.

# Anthropic API key for the editorial LLM calls (draft.py, summary.py).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Path to the directory containing Comext Parquet files (trade data).
# Optional: leave empty to skip the trade sections. When set, the monthly
# pipeline will read comext_export.parquet and comext_import.parquet from
# this folder and activate the trade_exports / trade_imports sections.
COMEXT_DATA_PATH=
