{
  "name": "iris-cms-api",
  "version": "0.1.0",
  "description": "Azure Function proxy for Iris CMS: commits MDX edits to GitHub with Entra ID identity",
  "private": true,
  "type": "module",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "start": "npm run build && func start",
    "test": "tsc -p tsconfig.test.json && node --test dist/test",
    "postinstall": "tsc"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@octokit/rest": "^21.0.2",
    "typescript": "^5.5.0",
    "@types/node": "^20.12.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20"
  }
}
